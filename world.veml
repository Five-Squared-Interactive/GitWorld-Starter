<?xml version="1.0" encoding="UTF-8"?>
<veml xmlns="http://www.fivesqd.com/schemas/veml/3.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <metadata>
    <title>The Overlook</title>
    <capability>javascript</capability>
    <script>scripts/lib/thirdpersoncharacter.js</script>
    <script>scripts/init.js</script>
    <script>scripts/bridge.js</script>
    <!-- Movement, mouse look, and jumping are handled natively by the
         WebVerse rig (see scripts/lib/thirdpersoncharacter.js). VR stick
         locomotion is enabled via the joystick-motion control flag below.
         Use <inputevent> elements here to wire additional inputs to your
         own JavaScript functions. -->
    <controlflags>
      <left-vr-pointer>teleport</left-vr-pointer>
      <right-vr-pointer>ui</right-vr-pointer>
      <left-vr-poker>false</left-vr-poker>
      <right-vr-poker>false</right-vr-poker>
      <left-hand-interaction>false</left-hand-interaction>
      <right-hand-interaction>false</right-hand-interaction>
      <turn-locomotion>snap</turn-locomotion>
      <joystick-motion>true</joystick-motion>
      <left-grab-move>true</left-grab-move>
      <right-grab-move>false</right-grab-move>
      <two-handed-grab-move>false</two-handed-grab-move>
    </controlflags>
    <!-- Multiplayer: activated automatically by the deploy workflow when
         the GitWorlds service is reachable. To disable, remove this block. -->
    <synchronizationservice type="vss"
        address="wss://mqtt.webverse.info:15526"
        id="REPLACE-WITH-YOUR-UUID"
        session="the-overlook" />
  </metadata>
  <environment>

    <!-- === ATMOSPHERE ===
         The procedural sky creates a dynamic backdrop with sun, clouds,
         and stars. Try changing day-sky-color or enabling day-night-cycle. -->
    <background>
      <lite-procedural-sky sun-entity-tag="sun"
                           day-night-cycle-enabled="false"
                           sun-enabled="true" sun-diameter="3"
                           ground-enabled="true" ground-color="#3a5a2a"
                           day-horizon-color="#e8a87c" day-sky-color="#1a5276"
                           clouds-enabled="true" stars-enabled="true"
                           moon-enabled="true" />
    </background>
    <effects>
      <lite-fog fog-enabled="true" color="#c8b89a" density="0.004" />
    </effects>

    <!-- === LIGHTING ===
         Directional light simulating the sun. The rotation controls
         the angle of sunlight and shadows. -->
    <entity xsi:type="light" tag="sun" id="9a6f662f-7b1e-43b7-8eff-52e101d45fb0">
      <transform xsi:type="scaletransform">
        <position x="0" y="75" z="0" />
        <rotation x="0.4177" y="-0.2506" z="0" w="0.8733" />
        <scale x="1" y="1" z="1" />
      </transform>
    </entity>

    <!-- === GROUND ===
         A large green plane as the terrain surface. Scale x and z
         control the size. The color is applied via the primitive. -->
    <entity xsi:type="planemesh" tag="ground" id="3bf15fb2-697f-4425-a41b-9eaaf717374d">
      <transform xsi:type="scaletransform">
        <position x="0" y="0" z="0" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="100" y="1" z="100" />
      </transform>
      <color>#3a6b35</color>
    </entity>

    <!-- === VIEWPOINT PLATFORM ===
         A stone platform where the player spawns. -->
    <entity xsi:type="cylindermesh" tag="platform" id="2a27392f-4bf2-4d5c-925d-fb7dea9702b1">
      <transform xsi:type="scaletransform">
        <position x="0" y="0.15" z="0" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="6" y="0.3" z="6" />
      </transform>
      <color>#8B8682</color>
    </entity>

    <!-- === PATH STONES ===
         Flat cylinders as stepping stones leading to the cabin.
         Copy a block and adjust position to extend the path. -->
    <entity xsi:type="cylindermesh" tag="path-stone" id="99b841c0-bb21-459c-8378-f9f32dc917d5">
      <transform xsi:type="scaletransform">
        <position x="2" y="0.06" z="3" />
        <rotation x="0" y="0.1" z="0" w="0.995" />
        <scale x="1.4" y="0.12" z="1.4" />
      </transform>
      <color>#9B9286</color>
    </entity>
    <entity xsi:type="cylindermesh" tag="path-stone" id="205fd07f-3ba3-42a0-bc18-7b31395a0928">
      <transform xsi:type="scaletransform">
        <position x="3.5" y="0.06" z="5.5" />
        <rotation x="0" y="0.3" z="0" w="0.954" />
        <scale x="1.2" y="0.12" z="1.2" />
      </transform>
      <color>#8B8378</color>
    </entity>
    <entity xsi:type="cylindermesh" tag="path-stone" id="ba951d2d-7512-4a87-a69c-449e83cec619">
      <transform xsi:type="scaletransform">
        <position x="5" y="0.06" z="8" />
        <rotation x="0" y="-0.2" z="0" w="0.98" />
        <scale x="1.3" y="0.12" z="1.3" />
      </transform>
      <color>#9B9286</color>
    </entity>

    <!-- === STRUCTURES ===
         Primitives arranged as a small shelter. Replace these with
         a mesh entity to use a real 3D model from the asset library. -->
    <!-- Cabin walls -->
    <entity xsi:type="cubemesh" tag="cabin" id="507cdf2d-ad42-42cd-a853-a7a9fed08089">
      <transform xsi:type="scaletransform">
        <position x="7" y="1.5" z="11" />
        <rotation x="0" y="0.383" z="0" w="0.924" />
        <scale x="4" y="3" z="0.2" />
      </transform>
      <color>#8B6914</color>
    </entity>
    <entity xsi:type="cubemesh" tag="cabin" id="d33eaeb1-ad24-413e-a1ce-9e72fd6d0035">
      <transform xsi:type="scaletransform">
        <position x="5.27" y="1.5" z="9.73" />
        <rotation x="0" y="0.924" z="0" w="0.383" />
        <scale x="3" y="3" z="0.2" />
      </transform>
      <color>#7B5B0A</color>
    </entity>
    <entity xsi:type="cubemesh" tag="cabin" id="d599d67e-24ce-4534-aa35-3f096716a705">
      <transform xsi:type="scaletransform">
        <position x="8.73" y="1.5" z="12.27" />
        <rotation x="0" y="0.924" z="0" w="0.383" />
        <scale x="3" y="3" z="0.2" />
      </transform>
      <color>#7B5B0A</color>
    </entity>
    <!-- Cabin roof -->
    <entity xsi:type="cubemesh" tag="cabin" id="3ca7fabe-d821-4781-a26c-f05f95ab5d98">
      <transform xsi:type="scaletransform">
        <position x="7" y="3.1" z="11" />
        <rotation x="0" y="0.383" z="0" w="0.924" />
        <scale x="4.6" y="0.2" z="3.6" />
      </transform>
      <color>#5C4033</color>
    </entity>

    <!-- === DECORATIVE PILLARS ===
         Stone pillars flanking the viewpoint platform. -->
    <entity xsi:type="cylindermesh" tag="pillar" id="362569b2-ddd5-4718-9291-40827e561c25">
      <transform xsi:type="scaletransform">
        <position x="-3" y="1" z="1" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.4" y="2" z="0.4" />
      </transform>
      <color>#A0998C</color>
    </entity>
    <entity xsi:type="spheremesh" tag="pillar-cap" id="8fb4eeb7-e655-4a1f-aa9d-100134cf6f49">
      <transform xsi:type="scaletransform">
        <position x="-3" y="2.1" z="1" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.6" y="0.3" z="0.6" />
      </transform>
      <color>#C8B89A</color>
    </entity>
    <entity xsi:type="cylindermesh" tag="pillar" id="11f8eb80-dcd9-40de-90b0-356437309e35">
      <transform xsi:type="scaletransform">
        <position x="3" y="1" z="1" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.4" y="2" z="0.4" />
      </transform>
      <color>#A0998C</color>
    </entity>
    <entity xsi:type="spheremesh" tag="pillar-cap" id="0a201cd1-371d-483d-9e9b-916da59f4682">
      <transform xsi:type="scaletransform">
        <position x="3" y="2.1" z="1" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.6" y="0.3" z="0.6" />
      </transform>
      <color>#C8B89A</color>
    </entity>

    <!-- === TREES ===
         Cone + cylinder primitives simulating trees. Replace with
         mesh entities from the asset library for realistic models.
         Example (uncomment when CDN is ready):
         <entity xsi:type="mesh" tag="tree" id="oak-1">
           <transform xsi:type="scaletransform">
             <position x="-8" y="0" z="6" />
             <rotation x="0" y="0" z="0" w="1" />
             <scale x="1" y="1" z="1" />
           </transform>
           <mesh-name>oak</mesh-name>
           <mesh-resource>https://cdn.webverse.info/library/nature/trees/oak-1.glb</mesh-resource>
         </entity>
    -->
    <!-- Tree 1 -->
    <entity xsi:type="cylindermesh" tag="trunk" id="25aa905d-1f25-46a7-b0dd-1b4d42f5bd6e">
      <transform xsi:type="scaletransform">
        <position x="-8" y="1.5" z="6" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.4" y="3" z="0.4" />
      </transform>
      <color>#5C4033</color>
    </entity>
    <entity xsi:type="conemesh" tag="foliage" id="f3ff6b49-41cf-4b2a-8edb-dba138567fe4">
      <transform xsi:type="scaletransform">
        <position x="-8" y="4.5" z="6" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="3" y="4" z="3" />
      </transform>
      <color>#2E7D32</color>
    </entity>
    <!-- Tree 2 -->
    <entity xsi:type="cylindermesh" tag="trunk" id="29f0ee8b-9c3d-4e65-842f-fd66464b3cb0">
      <transform xsi:type="scaletransform">
        <position x="-5" y="1.2" z="14" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.35" y="2.4" z="0.35" />
      </transform>
      <color>#6B4226</color>
    </entity>
    <entity xsi:type="conemesh" tag="foliage" id="dc870bdb-4c50-4362-9d44-e5b3ae03b2d4">
      <transform xsi:type="scaletransform">
        <position x="-5" y="3.6" z="14" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="2.5" y="3.5" z="2.5" />
      </transform>
      <color>#388E3C</color>
    </entity>
    <!-- Tree 3 -->
    <entity xsi:type="cylindermesh" tag="trunk" id="d792019b-052f-4710-b51f-a1d6292b979a">
      <transform xsi:type="scaletransform">
        <position x="12" y="1" z="5" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.5" y="2" z="0.5" />
      </transform>
      <color>#5C4033</color>
    </entity>
    <entity xsi:type="spheremesh" tag="foliage" id="816b97f4-4e0b-43ef-91f6-6d2a8f079a69">
      <transform xsi:type="scaletransform">
        <position x="12" y="3.5" z="5" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="4" y="3" z="4" />
      </transform>
      <color>#1B5E20</color>
    </entity>

    <!-- === WATER ===
         A small pond near the cabin. -->
    <entity xsi:type="planemesh" tag="water" id="85db6e98-e0d5-47d0-92ab-48c8d3978bc3">
      <transform xsi:type="scaletransform">
        <position x="12" y="0.05" z="14" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="6" y="1" z="4" />
      </transform>
      <color>#1A6B8A</color>
    </entity>

    <!-- === GLOWING ORBS ===
         Floating spheres that add visual interest. -->
    <entity xsi:type="spheremesh" tag="orb" id="f5813392-9d72-49a2-97c8-b8deeb690996">
      <transform xsi:type="scaletransform">
        <position x="-2" y="3" z="8" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.3" y="0.3" z="0.3" />
      </transform>
      <color>#FFD700</color>
    </entity>
    <entity xsi:type="spheremesh" tag="orb" id="8b2f9e88-c743-4810-a7c5-50317bbbaef9">
      <transform xsi:type="scaletransform">
        <position x="4" y="2.5" z="12" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.25" y="0.25" z="0.25" />
      </transform>
      <color>#FF6B35</color>
    </entity>
    <entity xsi:type="spheremesh" tag="orb" id="5554662f-5f3d-43e0-b523-b22d982def3f">
      <transform xsi:type="scaletransform">
        <position x="10" y="4" z="9" />
        <rotation x="0" y="0" z="0" w="1" />
        <scale x="0.35" y="0.35" z="0.35" />
      </transform>
      <color>#E040FB</color>
    </entity>

    <!-- === WELCOME PANEL ===
         Screen-space HTML overlay showing world info. Edit
         panels/welcome.html to customize the content. -->
    <entity xsi:type="html" tag="welcome-panel" id="414f638d-7f97-4195-88a9-8ed8a5b6f03c"
            url="panels/welcome.html"
            on-message="OnPanelMessage(?)">
      <transform xsi:type="canvastransform">
        <position-percent x="0.02" y="0.02" />
        <size-percent x="0.22" y="0.35" />
      </transform>
    </entity>

  </environment>
</veml>
